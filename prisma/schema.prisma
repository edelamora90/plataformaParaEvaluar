generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTIPLE_SELECT
  MATCHING
  ORDERING
  OPEN_TEXT
  CASE_ANALYSIS
}

enum AttemptStatus {
  STARTED
  SUBMITTED
  EVALUATING
  EVALUATED
  EXPIRED
  CANCELLED
}

enum EvaluatedBy {
  SYSTEM
  AI
  TEACHER
}

model User {
  id           String   @id @default(cuid())
  role         UserRole
  email        String?  @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  createdExams Exam[]     @relation("ExamCreator")
  auditLogs    AuditLog[] @relation("AuditActor")
}

model StudentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  controlNumber String   @unique
  fullName      String
  group         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  attempts ExamAttempt[]
  retries  RetryAuthorization[]
}

model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  authorizedRetries RetryAuthorization[] @relation("RetryAuthorizedBy")
}

model Exam {
  id                          String     @id @default(cuid())
  title                       String
  description                 String?
  status                      ExamStatus @default(DRAFT)
  accessCode                  String?
  startsAt                    DateTime?
  endsAt                      DateTime?
  durationMinutes             Int?
  oneAttemptOnly              Boolean    @default(true)
  shuffleQuestions            Boolean    @default(false)
  shuffleOptions              Boolean    @default(false)
  showResultToStudent         Boolean    @default(true)
  showCorrectAnswersToStudent Boolean    @default(false)
  createdById                 String?
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  createdBy User? @relation("ExamCreator", fields: [createdById], references: [id])

  questions Question[]
  attempts  ExamAttempt[]
  retries   RetryAuthorization[]
}

model Question {
  id                String       @id @default(cuid())
  examId            String
  section           String
  topic             String
  type              QuestionType
  prompt            String
  instructions      String?
  optionsJson       Json?
  correctAnswerJson Json?
  rubricJson        Json?
  points            Float
  order             Int
  difficulty        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  exam    Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@index([examId])
  @@index([section])
  @@index([topic])
}

model ExamAttempt {
  id              String        @id @default(cuid())
  examId          String
  studentId       String
  status          AttemptStatus @default(STARTED)
  attemptNumber   Int           @default(1)
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  expiresAt       DateTime?
  totalScore      Float         @default(0)
  maxScore        Float         @default(0)
  percentage      Float         @default(0)
  generalFeedback String?
  reportPath      String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  exam    Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@unique([examId, studentId, attemptNumber])
  @@index([examId])
  @@index([studentId])
  @@index([status])
}

model Answer {
  id               String      @id @default(cuid())
  attemptId        String
  questionId       String
  responseJson     Json
  score            Float       @default(0)
  maxScore         Float       @default(0)
  isCorrect        Boolean?
  feedback         String?
  evaluatedBy      EvaluatedBy @default(SYSTEM)
  aiEvaluationJson Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  attempt  ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model RetryAuthorization {
  id             String    @id @default(cuid())
  examId         String
  studentId      String
  authorizedById String
  reason         String
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  exam         Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  authorizedBy TeacherProfile @relation("RetryAuthorizedBy", fields: [authorizedById], references: [id])

  @@index([examId])
  @@index([studentId])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  entity       String
  entityId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entity])
}
